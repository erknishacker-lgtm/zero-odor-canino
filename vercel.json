{
  "trailingSlash": false,
  "rewrites": [
    { "source": "/upsell", "destination": "/upsell.html" },
    { "source": "/downsell", "destination": "/downsell.html" },
    { "source": "/obrigado", "destination": "/obrigado.html" },
    { "source": "/vendas", "destination": "/vendas.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(upsell|downsell|obrigado|vendas)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
